# Copy to .env and fill in. Never commit .env.
OPENAI_API_KEY=sk-...

# Spotify Web API (for searching tracks/playlists). Server-only — phone uses
# the Android SDK with the user's own logged-in Spotify app.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Tesla Fleet API (for vehicle status + commands).
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
TESLA_REDIRECT_URI=https://tessy.akashpatel.dev/tesla/callback
TESLA_DOMAIN=tessy.akashpatel.dev

# Optional — defaults shown
# WHISPER_MODEL=whisper-1
# LLM_MODEL=gpt-4o-mini
